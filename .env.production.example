# Backend Configuration for Production (Render)
FLASK_ENV=production
SECRET_KEY=your-secure-random-key-here-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-here-min-32-chars

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.com,https://your-frontend-domain.vercel.app

# Database (if using PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/authentify_db

# Tesseract OCR (optional for Render)
TESSERACT_CMD=tesseract

# File Upload Settings
MAX_FILE_SIZE_MB=25

# JWT Token Expiry
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000
