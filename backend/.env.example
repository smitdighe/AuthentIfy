# ── Flask Runtime ──────────────────────────────────────────
FLASK_ENV=development               # [optional] Environment mode: development | production (not read by config.py)
FLASK_DEBUG=1                       # [optional] Enable debug mode: 1 = on, 0 = off (default: 0)
FLASK_PORT=5000                     # [optional] Port the Flask server listens on (default: 5000)
FLASK_HOST=0.0.0.0                  # [optional] Host binding: 0.0.0.0 = all interfaces, 127.0.0.1 = localhost only (default: 0.0.0.0)
SECRET_KEY=change-me-to-a-random-secret-key   # [REQUIRED] Flask secret key — session signing; no default (generate a real one)
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret   # [REQUIRED] Secret for signing JWTs; no default — auth breaks if unset (generate a real one)
FRONTEND_URL=http://localhost:3000  # [optional] Allowed CORS origin for the frontend (default: http://localhost:3000)

# ── File Handling ──────────────────────────────────────────
MAX_FILE_SIZE_MB=25                 # Max upload size in megabytes (default: 25)
UPLOAD_FOLDER=uploads               # Directory for incoming PDF uploads (relative to backend/)
PROCESSED_FOLDER=processed          # Directory for vision-extracted page images (relative to backend/)
REPORTS_FOLDER=reports              # Directory for JSON verdict reports (relative to backend/)

# ── OCR Configuration ─────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract    # [optional] Path to Tesseract binary; if unset, relies on system PATH
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# macOS (Homebrew): /usr/local/bin/tesseract

# ── Machine Learning ──────────────────────────────────────
ML_CONTAMINATION=0.1                # [optional] IsolationForest contamination rate, 0.0 < value < 0.5 (default: 0.1)
