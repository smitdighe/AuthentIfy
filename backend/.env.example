# ============================================================
# .env.example — AuthentIfy Backend
# ============================================================
#
# Copy this file to .env and fill in your values:
#     cp .env.example .env
#
# Never commit .env to version control.
# Add .env to your .gitignore file.
#
# ============================================================

# ── Flask Runtime ──────────────────────────────────────────
FLASK_ENV=development               # Environment mode: development | production
FLASK_DEBUG=1                       # Enable debug mode: 1 = on, 0 = off
FLASK_PORT=5000                     # Port the Flask server listens on
FLASK_HOST=0.0.0.0                  # Host binding: 0.0.0.0 = all interfaces, 127.0.0.1 = localhost only
SECRET_KEY=change-me-to-a-random-secret-key   # Flask secret key — used for session signing (generate a real one)

# ── File Handling ──────────────────────────────────────────
MAX_FILE_SIZE_MB=25                 # Max upload size in megabytes (default: 25)
UPLOAD_FOLDER=uploads               # Directory for incoming PDF uploads (relative to backend/)
PROCESSED_FOLDER=processed          # Directory for vision-extracted page images (relative to backend/)
REPORTS_FOLDER=reports              # Directory for JSON verdict reports (relative to backend/)

# ── OCR Configuration ─────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract    # Path to Tesseract binary (Linux default shown)
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# macOS (Homebrew): /usr/local/bin/tesseract

# ── Machine Learning ──────────────────────────────────────
ML_CONTAMINATION=0.1                # IsolationForest contamination rate (0.0 < value < 0.5)
